// ── SOCKET.IO (UN SEUL BLOC FUSIONNÉ) ─────────────────────
// Stockage temporaire pour buzz & heatmap
let buzzQueue = [];
let heatmapData = {};

io.on('connection', (socket) => {
  console.log('✅ Connecté:', socket.id);
  
  // Rejoindre une room
  socket.on('join', ({ room, role }) => { 
    socket.join(room); 
    console.log(`📡 ${socket.id} -> ${room} (${role})`); 
  });
  
  // 📤 Modérateur envoie une question → Équipes
  socket.on('moderator:send_question', (data) => {
    console.log('📤 Question envoyée:', data.text || data.question);
    io.to('session-1').emit('game:new_question', {
      id: data.id,
      text: data.text || data.question,
      category: data.category || 'Général',
      points: data.points || 10,
      type: data.type || 'multiple_choice',
      timeLimit: data.timer || data.timeLimit || 30
    });
  });
  
  // 🔴 Équipe buzz → Modérateur
  socket.on('team:buzz', ({ teamId, teamName, questionId, buzzTime, points }) => {
    console.log('🔴 Buzz reçu:', { teamId, questionId, buzzTime });
    
    buzzQueue.push({ teamId, teamName, timestamp: Date.now(), buzzTime });
    buzzQueue.sort((a, b) => a.timestamp - b.timestamp);
    
    // Premier buzz → toutes les équipes
    io.to('session-1').emit('buzz:first', {
      teamId: buzzQueue[0].teamId,
      teamName: buzzQueue[0].teamName
    });
    
    // File d'attente → modérateur
    io.to('moderator-session').emit('buzz:queue', buzzQueue);
    
    // Réponse reçue → modérateur (format compatible frontend)
    io.to('moderator-session').emit('game:answer_received', {
      id: Date.now(),
      teamId: teamId || teamName || 'Équipe',
      questionId,
      questionText: 'Question en cours',
      buzzTime,
      answer: 'En attente...',
      points: points || 0,
      timestamp: new Date()
    });
  });
  
  // Fallback: ancien événement team:answer
  socket.on('team:answer', (data) => {
    io.to('moderator-session').emit('game:answer_received', data);
  });
  
  // 📝 Validation jury
  socket.on('jury:validate', ({ answerId, teamId, accepted, points, comment }) => {
    io.to('moderator-session').emit('jury:decision', { answerId, accepted, points, comment });
    if (accepted) {
      io.to('session-1').emit('score:update', { teamId, points });
    }
  });
  
  // 📊 Heatmap
  socket.on('answer:submit', ({ questionId, teamId, isCorrect }) => {
    if (!heatmapData[questionId]) heatmapData[questionId] = { correct: 0, wrong: 0 };
    if (isCorrect) heatmapData[questionId].correct++;
    else heatmapData[questionId].wrong++;
    io.to('public-room').emit('heatmap:update', { questionId, stats: heatmapData[questionId] });
  });
  
  // Déconnexion
  socket.on('disconnect', () => {
    console.log('❌ Déconnecté:', socket.id);
    // Nettoyer buzzQueue si besoin
    buzzQueue = buzzQueue.filter(b => b.teamId !== socket.id);
  });
});

// ── API: Heatmap ───────────────────────────────────────────
app.get('/api/heatmap', (req, res) => {
  res.json(heatmapData);
});

