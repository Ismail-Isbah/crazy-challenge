{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksPlan": {
      "setup": {
        "pkgs": ["nodejs-18"]
      },
      "phases": {
        "install": {
          "dependsOn": ["setup"],
          "cmds": ["cd backend && npm ci"],
          "cacheDirectories": ["backend/node_modules"]
        },
        "build": {
          "dependsOn": ["install"],
          "cmds": ["cd backend && npm run postinstall"]
        }
      },
      "start": {
        "cmd": "node backend/server.js"
      }
    }
  },
  "deploy": {
    "startCommand": "node backend/server.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100
  }
}
